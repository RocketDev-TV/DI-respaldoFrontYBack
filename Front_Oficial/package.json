{
  "name": "diseno-instruccional",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@apollo/client": "^4.2.0",
    "graphql": "^16.14.0",
    "lucide-react": "^1.18.0",
    "pg": "^8.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.1"
  },
  "scripts": {
